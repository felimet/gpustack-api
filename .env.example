# =============================================================================
# GPUStack 環境變數範本
# cp .env.example .env && vim .env
# =============================================================================

# GPUStack 版本（預設 v2.1.2）
GPUSTACK_VERSION=v2.1.2

# GPUStack 管理員密碼（首次啟動設定）
GPUSTACK_BOOTSTRAP_PASSWORD=

# GPUStack worker 連線 token（server 與 worker 共用相同值）
GPUSTACK_TOKEN=

# HuggingFace 存取 token（下載 gated 模型用）
HUGGINGFACE_TOKEN=

# 模型快取目錄（宿主機路徑，掛載至容器 /var/lib/gpustack/cache）
# WSL2 範例：/home/ai-user/models 或 /mnt/d/models
DATA_DIR=/opt/gpustack/data
CACHE_DIR=/opt/gpustack/cache
LOG_DIR=/opt/gpustack/logs

# Cloudflare Tunnel Token（Zero Trust → Tunnels → 建立後取得）
CLOUDFLARE_TUNNEL_TOKEN=